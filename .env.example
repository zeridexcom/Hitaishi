# Database (Supabase Postgres)
# App runtime — Transaction pooler (port 6543)
# Migrations — Session pooler (port 5432) via DIRECT_URL
# Format: postgresql://postgres.<ref>:<URL-ENCODED-password>@<region>.pooler.supabase.com:<port>/postgres
DATABASE_URL=
DIRECT_URL=

# Supabase project
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
# Personal Access Token — https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=

# Auth
AUTH_SECRET=change-me-to-32-bytes-random
AUTH_URL=http://localhost:3000

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Soketi / Pusher
SOKETI_HOST=localhost
SOKETI_PORT=6001
SOKETI_APP_ID=hitaishi
SOKETI_KEY=app-key
SOKETI_SECRET=app-secret

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=hitaishi

# Redis
REDIS_URL=redis://localhost:6379

# MSG91 (WhatsApp/SMS)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# Resend
RESEND_API_KEY=
RESEND_FROM=noreply@hitaishi.app

# Sentry / PostHog
SENTRY_DSN=
POSTHOG_KEY=
